# Homedash environment variables
HOMEDASH_PORT=5000
TZ=Asia/Yekaterinburg
CONFIG_FILE=./data/config.json
ICONS_CONFIG_PATH=./data/icons.json

# API ключ для админ-панели (оставьте пустым для отключения auth)
#ADMIN_API_KEY=

# Таймауты проверок
CHECK_TIMEOUT=5s
PING_TIMEOUT=5s

# WAN IP settings
IP_PROVIDERS=https://api.ipify.org,https://icanhazip.com,https://ifconfig.co/ip,https://ident.me
IP_CACHE_TTL=30m

# Performance optimization settings
MAX_WORKERS=5
USE_LRU_CACHE=false
LRU_CACHE_CAPACITY=1000
LRU_CACHE_TTL=5m
IDLE_TIMEOUT=1m
LAZY_CHECK_INTERVAL=2m