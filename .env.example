# Homedash environment variables
# Скопируйте в .env и измените значения

# Порт веб-интерфейса
HOMEDASH_PORT=5000

# Часовой пояс
TZ=Europe/Moscow

# Путь к файлу конфигурации (по умолчанию ./data/config.json)
CONFIG_FILE=./data/config.json

# API ключ для админ-панели (оставьте пустым для отключения auth)
#ADMIN_API_KEY=

# Таймауты проверок
CHECK_TIMEOUT=2s
PING_TIMEOUT=1s

# WAN IP settings
IP_PROVIDERS=https://api.ipify.org,https://icanhazip.com,https://ifconfig.co/ip,https://ident.me
IP_CACHE_TTL=10m

# Performance optimization settings
MAX_WORKERS=20                    # Maximum number of parallel workers for service checks
USE_LRU_CACHE=false               # Whether to use LRU cache instead of simple map
LRU_CACHE_CAPACITY=1000           # Maximum number of entries in LRU cache (0 = unlimited)
LRU_CACHE_TTL=5m                  # TTL for cache entries (0 = no expiration)
IDLE_TIMEOUT=5m                   # Пауза проверок при простое
MAX_WORKERS=20                    # Лимит одновременных проверок